PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ecommerce
JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development

# optional default admin credentials used by seeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=securepassword

# Note: 
# - For local development, use: mongodb://localhost:27017/ecommerce
# - For production (Render), use MongoDB Atlas URI above
# - Make sure to replace username, password, and cluster details with your actual MongoDB Atlas credentials

